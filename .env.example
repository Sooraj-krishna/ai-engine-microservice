# Website configuration
WEBSITE_URL=https://yoursite.com
MONITORING_MODE=ga_only     # Google analytics only

# Google Analytics configuration
GA4_PROPERTY_ID=123456789  # Your GA4 property ID (get from GA dashboard)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Competitive Analysis
# Add URLs of competitor/similar sites separated by commas
COMPETITOR_URLS=https://example1.com,https://example2.com,https://example3.com
ENABLE_COMPETITIVE_ANALYSIS=true
AUTO_RUN_COMPETITIVE_ANALYSIS=false

# Competitive Analysis Depth Settings
COMPETITIVE_ANALYSIS_DEPTH=standard  # Options: basic, standard, deep
COMPETITIVE_MAX_PAGES_PER_SITE=5  # Number of pages to crawl per site (deep mode only)
COMPETITIVE_ENABLE_PERFORMANCE_METRICS=true  # Collect performance metrics (deep mode)
COMPETITIVE_ENABLE_DESIGN_SYSTEM_ANALYSIS=true  # Extract design system tokens (deep mode)
COMPETITIVE_ENABLE_MULTIPAGE_CRAWL=false  # Enable multi-page crawling (expensive, deep mode)

# Premium Analysis Settings
ENABLE_PREMIUM_ANALYSIS=true  # Enable premium competitive analysis features
PREMIUM_ANALYSIS_TIMEOUT=300000  # 5 minutes timeout for premium analysis

# Log file paths (commented out for Vercel deployment)
# ACCESS_LOG_PATH=/var/log/nginx/access.log
# ERROR_LOG_PATH=/var/log/nginx/error.log
# APP_LOG_PATH=logs/app.log

# GitHub and AI configuration (unchanged)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=yourusername/yourrepo
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash
