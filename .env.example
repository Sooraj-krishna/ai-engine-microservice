# Website configuration
WEBSITE_URL=https://yoursite.com
MONITORING_MODE=ga_only     # Google analytics only

# Google Analytics configuration
GA4_PROPERTY_ID=123456789  # Your GA4 property ID (get from GA dashboard)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Log file paths (commented out for Vercel deployment)
# ACCESS_LOG_PATH=/var/log/nginx/access.log
# ERROR_LOG_PATH=/var/log/nginx/error.log
# APP_LOG_PATH=logs/app.log

# GitHub and AI configuration (unchanged)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=yourusername/yourrepo
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash
